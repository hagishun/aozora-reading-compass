---
// 静的ページ: 気分を4択させる入口画面
import BaseLayout from '../layouts/BaseLayout.astro';
export const prerender = true;

const choices = [
  { state: 'recovery', label: '回復したい', desc: 'やさしさに包まれたい' },
  { state: 'thinking', label: '考えたい', desc: '思索に沈みたい' },
  { state: 'stimulus', label: '刺激がほしい', desc: '心を揺さぶられたい' },
  { state: 'quiet',    label: '静かに読みたい', desc: '夜更けの一篇を' },
] as const;
---

<BaseLayout title="Aozora Reading Compass">
  <h1>Aozora Reading Compass</h1>
  <p class="lede">今日の気分は、どれに近いですか。</p>
  <div class="choices">
    {choices.map(c => (
      <a class="choice" href={`/pick?state=${c.state}`}>
        <strong>{c.label}</strong>
        <span>{c.desc}</span>
      </a>
    ))}
  </div>
</BaseLayout>

<style>
  h1 { font-size: 1.6rem; }
  .lede { color: var(--fg-muted); margin-bottom: 2.5rem; }
  .choices { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .choice {
    display: block;
    padding: 1.5rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    text-decoration: none;
    transition: border-color .2s, background .2s;
  }
  .choice:hover { border-color: var(--fg); background: var(--surface); }
  .choice strong { display: block; font-size: 1.1rem; margin-bottom: .3rem; }
  .choice span { color: var(--fg-faint); font-size: .9rem; }
  @media (max-width: 480px) {
    .choices { grid-template-columns: 1fr; }
  }
</style>
